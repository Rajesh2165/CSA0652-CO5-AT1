def count_satisfied(clauses, assignment):
    count = 0

    for clause in clauses:
        satisfied = False

        for literal in clause:
            variable = abs(literal)

            if literal > 0 and assignment[variable]:
                satisfied = True

            elif literal < 0 and not assignment[variable]:
                satisfied = True

        if satisfied:
            count += 1

    return count

def max_sat(variables, clauses):

    best_count = 0
    best_assignment = None

    def backtrack(index, assignment):

        nonlocal best_count, best_assignment

        if index > variables:

            satisfied = count_satisfied(clauses, assignment)

            if satisfied > best_count:
                best_count = satisfied
                best_assignment = assignment.copy()

            return

        assignment[index] = True
        backtrack(index + 1, assignment)

        assignment[index] = False
        backtrack(index + 1, assignment)

    backtrack(1, {})

    return best_count, best_assignment

clauses = [
    [1, -2],
    [-1, 3],
    [2, 3]
]

variables = 3

max_clauses, assignment = max_sat(variables, clauses)

print("Maximum Satisfied Clauses =", max_clauses)
print("Best Assignment =", assignment)
